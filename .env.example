# Magister backend - modelo de variaveis de ambiente.
# Copie para .env e preencha. NUNCA versione o .env real.

# --- App ---
APP_ENV=development
CORS_ALLOW_ORIGINS=http://localhost:5173
# Base do widget para o snippet <iframe> (rota /embed do frontend).
WIDGET_BASE_URL=http://localhost:5173

# --- Auth admin (JWT) ---
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
JWT_EXPIRE_MINUTES=60
ADMIN_USERNAME=admin
# Gere com: python -c "import bcrypt;print(bcrypt.hashpw(b'suasenha',bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# --- Persistencia ---
DATABASE_URL=sqlite:///./magister.db

# --- Conversa / limites ---
HISTORY_WINDOW=40
MAX_OUTPUT_TOKENS=800
MAX_TOKENS_PER_SESSION=50000
CHAT_RATE_LIMIT_PER_MIN=20

# --- Fontes (SSRF guard) ---
FETCH_TIMEOUT_SECONDS=8
FETCH_MAX_BYTES=200000

# --- LLM router (por custo; JSON) ---
# Lista ordenada por prioridade (menor custo primeiro). Groq e OpenAI-compativel; OpenRouter idem.
# model = padrao do provedor (rapido/barato, Llama 3.1 8B).
# task_models = override por tarefa DENTRO do provedor (knowledge|persona|guardrail|summarize);
# use aqui porque o id do modelo forte difere entre provedores (Groq vs OpenRouter),
# assim o failover por tarefa continua valido. Persona (conversa) usa o Llama 3.3 70B.
# api_key aceita varias chaves separadas por virgula (rotacao/diluir free tier).
LLM_PROVIDERS=[{"name":"groq","base_url":"https://api.groq.com/openai/v1","api_key":"","model":"llama-3.1-8b-instant","task_models":{"persona":"llama-3.3-70b-versatile"},"priority":1},{"name":"openrouter","base_url":"https://openrouter.ai/api/v1","api_key":"","model":"meta-llama/llama-3.1-8b-instruct","task_models":{"persona":"meta-llama/llama-3.3-70b-instruct"},"priority":2}]
# Override global tarefa->modelo (aplicado a todos os provedores; task_models do provedor tem precedencia).
LLM_TASK_MODELS={}
