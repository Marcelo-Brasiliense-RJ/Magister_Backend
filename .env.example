# Magister backend - modelo de variaveis de ambiente.
# Copie para .env e preencha. NUNCA versione o .env real.

# --- App ---
APP_ENV=development
CORS_ALLOW_ORIGINS=http://localhost:5173
# Base do widget para o snippet <iframe> (rota /embed do frontend).
WIDGET_BASE_URL=http://localhost:5173

# --- Auth admin (JWT) ---
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
JWT_EXPIRE_MINUTES=60
ADMIN_USERNAME=admin
# Gere com: python -c "import bcrypt;print(bcrypt.hashpw(b'suasenha',bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# --- Persistencia ---
DATABASE_URL=sqlite:///./magister.db

# --- Conversa / limites ---
HISTORY_WINDOW=40
MAX_OUTPUT_TOKENS=800
MAX_TOKENS_PER_SESSION=50000
CHAT_RATE_LIMIT_PER_MIN=20

# --- Fontes (SSRF guard) ---
FETCH_TIMEOUT_SECONDS=8
FETCH_MAX_BYTES=200000

# --- LLM router (por custo; JSON) ---
# Lista ordenada por prioridade (menor custo primeiro). Groq e OpenAI-compativel; OpenRouter idem.
# roles opcionais mapeiam modelo por tarefa: knowledge | persona | guardrail | summarize
LLM_PROVIDERS=[{"name":"groq","base_url":"https://api.groq.com/openai/v1","api_key":"","model":"llama-3.1-8b-instant","priority":1},{"name":"openrouter","base_url":"https://openrouter.ai/api/v1","api_key":"","model":"meta-llama/llama-3.1-8b-instruct","priority":2}]
# Modelo por tarefa (opcional): barato p/ guardrail/summarize, forte p/ persona.
# api_key aceita varias chaves separadas por virgula (rotacao/diluir free tier).
LLM_TASK_MODELS={}
